# Docker 部署环境变量
# 本地开发: scripts/deploy.sh（源码构建，双端口）
# 生产服务器: ./deploy.sh <version>（单域名反代，仅暴露 WEB_PORT）

# ── 生产必填 ──────────────────────────────────────────
# 公网访问地址（单域名，Web 和 API 共用）
# 示例: https://sms.example.com
PUBLIC_URL=

# CORS 允许来源，生产环境应与 PUBLIC_URL 一致
CORS_ORIGIN=

# Docker 绑定到本机的端口，供宿主机 nginx 反代（默认 8080）
WEB_PORT=8080

# ── 密钥（首次 deploy 可留空，脚本自动生成）────────────
DATABASE_ENCRYPTION_KEY=
JWT_SECRET=
# 密码指纹 HMAC pepper，独立于 JWT，轮换 JWT 时勿改
PASSWORD_PEPPER=

# ── 本地开发专用 ─────────────────────────────────────
DATABASE_PATH=./data/smsrelay.db
MIGRATIONS_DIR=./server/db/migrations

# 本地 docker-compose.yml 开发时 API 直连端口（生产 compose 不使用）
API_PORT=8080
